# === Frontend (Vite) ===
# Supabase connection
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Pi camera server address (used by the frontend to connect)
VITE_PI_HOSTNAME="raspberrypi.local"
VITE_PI_CAMERA_PORT="8080"

# === Server-side (Docker / Pi) ===
# Camera device path
CAMERA_DEVICE="/dev/video0"

# Where recordings are stored on the Pi
RECORDING_PATH="/var/recordings"

# Node environment
NODE_ENV="production"
